{% extends '@EasyAdmin/page/content.html.twig' %} {% block content %}
<div class="container">
    <h1>Dashboard</h1>
    <h2>Les trois derniers rendez-vous</h2>
    <table class="appointments_table">
        <thead>
            <tr>
                <th>Date de début</th>
                <th>Date de fin</th>
                <th>Message</th>
                <th>Client</th>
                <th>Email</th>
            </tr>
        </thead>
        <tbody>
            {% set sorted_appointments = appointments|sort((a, b) => b.startDate
            <=> a.startDate) %} {% for appointment in sorted_appointments %}
            <tr id="appointment-{{ appointment.id }}">
                <td data-label="Date de début">
                    {{ appointment.startDate|date('d-m-Y H:i') }}
                </td>
                <td data-label="Date de fin">
                    {{ appointment.endDate|date('d-m-Y H:i') }}
                </td>
                <td data-label="Message">{{ appointment.message }}</td>
                <td data-label="Client">{{ appointment.name }}</td>
                <td data-label="Email">{{ appointment.email }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <div>
        <canvas
            id="quotes_chart"
            data-quotesbystate='{{ quotesByStateJson|e('html_attr') }}'
        ></canvas>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const ctx = document.getElementById('quotes_chart'); // Récupère le canvas
        const quotesByState = JSON.parse(ctx.dataset.quotesbystate); // Récupère les données
        const labels = quotesByState.map(item => item.state); // Récupère les labels
        console.log(quotesByState)
        const data = quotesByState.map(item => item.count); // Récupère les données
    
        new Chart(ctx, {
            type: 'polarArea',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Nombre de devis',
                    data: data,
                    backgroundColor: [
                        '#b6b6b6',
                        '#27B474',
                        '#fbfb8f',
                        '#6C6CFF',
                    ],
                    hoverOffset: 4
                }]
            },
            options: {
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>

    {% endblock %}
